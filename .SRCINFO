pkgbase = power-control-center
	pkgdesc = GUI power management for Linux laptops — CPU (Intel/AMD), GPU (NVIDIA/Arc/AMD), battery, TLP, daemons, sensors
	pkgver = 1.1.1
	pkgrel = 1
	url = https://github.com/mehmetbayoglu/power-control-center
	arch = any
	license = MIT
	depends = python
	depends = tk
	depends = polkit
	optdepends = power-profiles-daemon: profile switching (EPP, platform profile, turbo)
	optdepends = tlp: peripheral power management + coexist mode with ppd
	optdepends = thermald: Intel thermal daemon control
	optdepends = auto-cpufreq: automatic CPU frequency/governor optimizer
	optdepends = nvidia-utils: NVIDIA GPU power limit, stats, and runtime PM
	optdepends = nvtop: GPU monitor (launched from GPU tab)
	optdepends = turbostat: CPU turbostat sampling (CPU tab)
	optdepends = stress-ng: CPU stress testing (Tools tab)
	optdepends = s-tui: terminal stress/monitoring TUI (Tools tab)
	optdepends = powertop: power consumption analysis and auto-tune (Tools tab)
	optdepends = lm_sensors: hardware sensor readings (Sensors tab)
	optdepends = upower: battery status, energy rate, cycle count
	optdepends = acpi: battery detail output
	source = power-control-center-1.1.1.py::https://raw.githubusercontent.com/mehmetbayoglu/power-control-center/v1.1.1/power-control-center.py
	source = power-control-center.desktop
	sha256sums = 1355b6e6720b8e94d93df621477e18a8cde92c3adaa1305b57cc8f8e8eb29e2c
	sha256sums = 4a2f295a0bb18deb2c96837c81fb22faa97c1f839fc4393ead89d2352c88c35e

pkgname = power-control-center
